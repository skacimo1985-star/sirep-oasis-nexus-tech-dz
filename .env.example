# ===========================================
# SIREP OASIS NEXUS TECH DZ - Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ===========================================

# Application
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sirep_db
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_this_strong_password
MONGO_DB_NAME=sirep_db

# JWT Secrets (use strong random strings, min 64 chars)
JWT_SECRET=replace_with_strong_random_64_char_string_here_xxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace_with_different_strong_random_64_char_string_yyyyyyyyyyy
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (32 byte hex key for AES-256)
ENCRYPTION_KEY=replace_with_32_byte_hex_key_64_chars_long_zzzzzzzzzzzzzzzzzzzz

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ThingSpeak IoT Integration
THINGSPEAK_API_KEY=your_thingspeak_api_key_here
THINGSPEAK_CHANNEL_ID=your_channel_id_here
THINGSPEAK_BASE_URL=https://api.thingspeak.com

# Frontend (Vite)
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Email (optional, for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
